# =============================================================================
# JusAds Backend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -- Application runtime ---
ENVIRONMENT=development
# Comma-separated browser origins allowed to call the API directly.
# Production normally uses same-origin Nginx proxying, e.g. https://jusads.com.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -- LangSmith (LangGraph tracing) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=JusAds

# -- AWS (S3 storage) ---
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# -- LLM Model ---
LLM_MODEL_ID=gemini-3.1-flash-lite
EMBED_DIMENSIONS=1536

# -- Qdrant (vector DB for regulatory RAG) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TOP_K=5

# -- Google Vertex AI (Gemini + Veo video generation) ---
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
VERTEX_GCS_BUCKET=

# -- HuggingFace (SAM3 model weights) ---
HUGGINGFACE_ACCESS_TOKEN=

# -- Tavily (research/search API) ---
TAVILY_API_KEY=

# -- FluxAI (image editing) ---
FLUXAI_API_KEY=

# -- KIE.ai (Kling video generation) ---
KIE_API_KEY=

# -- ElevenLabs (TTS + sound effects) ---
ELEVENLABS_API_KEY=

# ElevenLabs Voice IDs (Malaysia)
ELEVENLABS_VOICE_MY_MS_MALE=
ELEVENLABS_VOICE_MY_MS_FEMALE=
ELEVENLABS_VOICE_MY_EN_CHI_MALE=
ELEVENLABS_VOICE_MY_EN_CHI_FEMALE=
ELEVENLABS_VOICE_MY_ZH_MALE=
ELEVENLABS_VOICE_MY_ZH_FEMALE=
ELEVENLABS_VOICE_MY_YUE=
ELEVENLABS_VOICE_MY_EN_IND_MALE=
ELEVENLABS_VOICE_MY_EN_IND_FEMALE=

# ElevenLabs Voice IDs (Singapore)
ELEVENLABS_VOICE_SG_EN_MALE=
ELEVENLABS_VOICE_SG_EN_FEMALE=
ELEVENLABS_VOICE_SG_ZH_MALE=
ELEVENLABS_VOICE_SG_ZH_FEMALE=

# -- Supabase (PostgreSQL database) ---
SUPABASE_URL=
SUPABASE_KEY=

# -- Zernio (social distribution: TikTok + Instagram) ---
ZERNIO_API_KEY=
ZERNIO_ACCOUNT_TIKTOK=
ZERNIO_ACCOUNT_INSTAGRAM=

# -- Apify (web scraping for trends) ---
APIFY_API_TOKEN=

# -- PredictHQ (events calendar for trends) ---
PREDICTHQ_API_KEY=
