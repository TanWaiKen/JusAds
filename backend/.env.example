# =============================================================================
# JusAds Backend — Environment Variables (Standardized)
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git — it is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEBUG=true
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./app.db

# -----------------------------------------------------------------------------
# AWS (for Bedrock Flow + Titan Embeddings + Claude)
# -----------------------------------------------------------------------------
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Only needed if using temporary credentials (IAM role / SSO):
# AWS_SESSION_TOKEN=your-session-token

# Models for Culture Compliance
EMBED_MODEL_ID=global.cohere.embed-v4:0
AWS_LLM_MODEL_ID=apac.amazon.nova-pro-v1:0
GOOGLE_LLM_MODEL_ID=gemini-3.0-pro

# Suggested to use Google 3.0 Pro for everything
LLM_MODEL_ID=gemini-3.0-pro
EMBED_DIMENSIONS=1536

# S3 (for transcription temp files and video upload)
TRANSCRIBE_S3_BUCKET=your-transcribe-s3-bucket-name

# Video Understanding (TwelveLabs Pegasus)
VIDEO_MODEL_ID=global.twelvelabs.pegasus-1-2-v1:0

# -----------------------------------------------------------------------------
# Qdrant (for MCMC regulatory guidelines RAG)
# -----------------------------------------------------------------------------
QDRANT_URL=your-qdrant-url
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=mcmc-guidelines
QDRANT_TOP_K=50

# -----------------------------------------------------------------------------
# ElevenLabs (for audio + sound effects generation)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# -----------------------------------------------------------------------------
# Google Gemini (for image/asset generation and Vertex AI text compliance)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_ID=gemini-3.1-pro-preview
VERTEX_PROJECT_ID=your-vertex-project-id
VERTEX_LOCATION=global

# -----------------------------------------------------------------------------
# KIE.ai (for video generation via Kling 2.5)
# -----------------------------------------------------------------------------
KIE_API_KEY=your-kie-api-key

# -----------------------------------------------------------------------------
# Celery (task queue — needs Redis running)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

