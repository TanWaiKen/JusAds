# ============================================================
# JusAds Production Environment Variables
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to Git.
# ============================================================

# ── Google Vertex AI / Gemini ──────────────────────────────
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global

# ── AWS Credentials & S3 ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── ElevenLabs ────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Tavily (Web Search) ──────────────────────────────────
TAVILY_API_KEY=
TAVILY_ENABLED=true

# ── PredictHQ (Events Calendar) ──────────────────────────
PREDICTHQ_API_KEY=

# ── FluxAI ────────────────────────────────────────────────
FLUXAI_API_KEY=

# ── Zernio Distribution ──────────────────────────────────
ZERNIO_API_KEY=
ZERNIO_ACCOUNT_TIKTOK=
ZERNIO_ACCOUNT_INSTAGRAM=
